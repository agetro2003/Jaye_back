{
    "name": "Jaye Backend (Python 3.8 & PostgreSQL)",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

    // Exponemos el puerto 8000 (típico para FastAPI/Flask) y el 5432 (PostgreSQL)
    "forwardPorts": [8000, 5432],

    // Descomenta la siguiente línea cuando crees tu archivo requirements.txt
    // "postCreateCommand": "pip install -r requirements.txt",

    // Configuraciones y extensiones recomendadas para VS Code
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    }
}